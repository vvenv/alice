{
  "name": "alice-dictation",
  "version": "0.2.1",
  "private": true,
  "main": "index.js",
  "packageManager": "pnpm@11.13.1",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "build": "ALICE_WEB_BUILD=1 expo export --platform web --output-dir dist && node scripts/flatten-web-dist.mjs",
    "build:android": "eas build --platform android --non-interactive",
    "build:ios": "eas build --platform ios --non-interactive",
    "build:android:local": "eas build --platform android --non-interactive --local --profile preview",
    "build:ios:local": "eas build --platform ios --non-interactive --local --profile preview",
    "release:android": "bash scripts/release.sh",
    "release:website": "bash scripts/release-website.sh",
    "release:webapp": "bash scripts/release-webapp.sh",
    "dict:build": "python3 scripts/build-ecdict-meta.py",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@babel/runtime": "^8.0.0",
    "@expo-google-fonts/noto-serif-sc": "^0.4.3",
    "@expo-google-fonts/playfair-display": "^0.4.2",
    "@expo/metro-runtime": "^57.0.5",
    "@expo/vector-icons": "^15.1.1",
    "@react-native-async-storage/async-storage": "^3.1.1",
    "@react-navigation/native": "^7.3.8",
    "@react-navigation/native-stack": "^7.17.10",
    "babel-preset-expo": "^57.0.3",
    "expo": "^57.0.6",
    "expo-asset": "^57.0.5",
    "expo-audio": "^57.0.2",
    "expo-clipboard": "^57.0.1",
    "expo-constants": "^57.0.5",
    "expo-file-system": "^57.0.1",
    "expo-font": "^57.0.1",
    "expo-haptics": "^57.0.1",
    "expo-image-manipulator": "^57.0.4",
    "expo-image-picker": "^57.0.4",
    "expo-linear-gradient": "^57.0.1",
    "expo-speech": "^57.0.1",
    "expo-splash-screen": "^57.0.4",
    "expo-status-bar": "^57.0.1",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-native": "0.86.0",
    "react-native-safe-area-context": "^5.8.0",
    "react-native-screens": "^4.26.1",
    "react-native-svg": "^15.15.5",
    "react-native-web": "^0.21.2"
  },
  "devDependencies": {
    "@babel/core": "^8.0.1",
    "@babel/plugin-transform-runtime": "^8.0.1",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "prettier": "^3.9.5",
    "typescript": "^6.0.3"
  },
  "expo": {
    "install": {
      "exclude": [
        "@babel/core",
        "@babel/plugin-transform-runtime",
        "@babel/runtime"
      ]
    },
    "doctor": {
      "appConfigFieldsNotSyncedCheck": {
        "enabled": false
      }
    }
  }
}
