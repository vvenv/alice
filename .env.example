# Copy to .env and fill in your own values. .env is gitignored — never commit it.

# 智谱 AI API Key（OCR 拍照识词），申请：https://open.bigmodel.cn/
ZHIPU_API_KEY=your-zhipu-api-key

# 解锁码 HMAC 密钥（生成/校验 OCR 付费解锁码），任意足够长的随机字符串
ALICE_HMAC_SECRET=your-random-secret

# 发布部署目标（scripts/release.sh 使用，可选）
DEPLOY_SERVER=user@your.server.ip
DEPLOY_REMOTE_DIR=/var/www/alice
