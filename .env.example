# 本地开发 — 复制为 .env.local（勿提交）
# 部署变量见 scripts/env.production.example

# SSH 部署（与 GitHub Secrets 同名）
DEPLOY_HOST=
DEPLOY_SSH_USER=
DEPLOY_SSH_PASSWORD=

# 服务器
PORT=3600
HOST=0.0.0.0
LOG_LEVEL=info
NODE_ENV=development

# 使用码（四位数字，保护前端入口与 /api 接口，默认 1024）
ACCESS_CODE=1024

# 智谱 AI — TTS / 视觉 OCR
# https://open.bigmodel.cn/usercenter/apikeys
OPENAI_API_KEY=
OPENAI_BASE_URL=https://open.bigmodel.cn/api/paas/v4
OPENAI_TTS_MODEL=glm-tts
OPENAI_TTS_VOICE=6f62ac26-895b-512e-990f-7a0bbf06e75e
OPENAI_VISION_MODEL=glm-4v-flash
