{
  "expo": {
    "name": "Alice 听写",
    "slug": "alice-dictation",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.vvenv.alice",
      "infoPlist": {
        "NSCameraUsageDescription": "用于拍摄单词图片进行 OCR 识别",
        "UIBackgroundModes": [
          "audio"
        ]
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#ffffff"
      },
      "package": "com.vvenv.alice",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.FOREGROUND_SERVICE_MEDIA_PLAYBACK"
      ],
      "versionCode": 2
    },
    "plugins": [
      [
        "expo-image-picker",
        {
          "cameraPermission": "用于拍摄单词图片进行 OCR 识别"
        }
      ],
      [
        "expo-audio",
        {
          "microphonePermission": false
        }
      ],
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#ffffff"
        }
      ]
    ],
    "updates": {
      "enabled": false
    },
    "extra": {
      "zhipuApiKey": "YOUR_ZHIPU_API_KEY",
      "zhipuBaseUrl": "https://open.bigmodel.cn/api/paas/v4",
      "visionModel": "glm-4v-flash",
      "hmacSecret": "YOUR_HMAC_SECRET",
      "wechatId": "vvenvw",
      "eas": {
        "projectId": "c3f70d10-17f5-49fe-90b2-7a73d3beb382"
      }
    },
    "owner": "vvenv"
  }
}
